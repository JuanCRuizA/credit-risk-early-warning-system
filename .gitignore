# =========================
# Credit Risk Project .gitignore
# =========================

# ----- DATA FILES (CRITICAL - Never upload data to GitHub) -----
data/raw/
data/processed/
*.csv
*.xlsx
*.xls
*.db
*.sqlite
*.parquet
*.feather
*.h5
*.hdf5

# ----- SECRETS AND CREDENTIALS -----
.env
.env.local
.env.*.local
*.pem
*.key
config/secrets.yaml
config/credentials.yaml

# ----- API KEYS -----
*api_key*
*apikey*
*secret*

# ----- PYTHON -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ----- VIRTUAL ENVIRONMENTS -----
venv/
ENV/
env/
.venv/

# ----- JUPYTER NOTEBOOKS -----
.ipynb_checkpoints/
*.ipynb_checkpoints/

# ----- IDE AND EDITORS -----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ----- OS FILES -----
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ----- MODEL FILES (Large files) -----
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.onnx

# ----- LOGS AND OUTPUTS -----
logs/
*.log
output/
tmp/
temp/

# ----- REPORTS (Keep templates, ignore generated) -----
reports/*.html
reports/*.pdf
!reports/.gitkeep

# ----- STREAMLIT -----
.streamlit/secrets.toml

# ----- DASHBOARD ARTIFACTS (small files needed for Streamlit Cloud) -----
!test_dashboard.csv
!models/xgb_credit_model.pkl
!models/thresholds.pkl
!models/feature_names.pkl
!models/label_encoders_v2.pkl
!models/categorical_modes.pkl
!models/population_medians.csv  
!models/xgb_credit_model.pkl 
